      <Textbox Name="V12_Textbox3">
        <CanGrow>true</CanGrow>
        <KeepTogether>true</KeepTogether>
        <Paragraphs>
          <Paragraph>
            <TextRuns>
              <TextRun>
                <Value xml:space="preserve">  </Value>
                <Style>
                  <FontFamily>AngsanaUPC</FontFamily>
                  <FontSize>16pt</FontSize>
                  <FontWeight>Bold</FontWeight>
                  <TextDecoration>None</TextDecoration>
                </Style>
              </TextRun>
              <TextRun>
                <Value>หมายเหตุ</Value>
                <Style>
                  <FontFamily>AngsanaUPC</FontFamily>
                  <FontSize>16pt</FontSize>
                  <FontWeight>Bold</FontWeight>
                  <TextDecoration>Underline</TextDecoration>
                </Style>
              </TextRun>
              <TextRun>
                <Value>        1. มูลค่ากรมธรรม์ประกันภัยข้างต้น เป็นมูลค่าก่อนหักหนี้สินใดๆ</Value>
                <Style>
                  <FontFamily>AngsanaUPC</FontFamily>
                  <FontSize>16pt</FontSize>
                  <FontWeight>Normal</FontWeight>
                  <TextDecoration>None</TextDecoration>
                </Style>
              </TextRun>
            </TextRuns>
            <Style />
          </Paragraph>
          <Paragraph>
            <TextRuns>
              <TextRun>
                <Value>                          2. เงินค่าเวนคืนกรมธรรม์ประกันภัยที่แสดงไว้ในตราราง เป็นจำนวนเงินที่หักเงินจ่ายคืน (ถ้ามี) ออกแล้ว</Value>
                <Style>
                  <FontFamily>AngsanaUPC</FontFamily>
                  <FontSize>16pt</FontSize>
                  <FontWeight>Normal</FontWeight>
                  <TextDecoration>None</TextDecoration>
                </Style>
              </TextRun>
            </TextRuns>
            <Style />
          </Paragraph>
        </Paragraphs>
        <rd:DefaultName>V12_Textbox3</rd:DefaultName>
